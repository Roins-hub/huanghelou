{
  "name": "huanghelou-digital-gallery",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build && node local-dev-server.js",
    "test": "vitest run",
    "build": "npm run install:assistant && npm --prefix assistant-app run build",
    "build:vercel": "npm run build && node scripts/build-vercel-output.js",
    "install:assistant": "npm --prefix assistant-app install"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  },
  "version": "1.0.0",
  "description": "一个基于 `Three.js + MediaPipe Hands` 的纯静态网页项目，用于展示黄鹤楼 3D 模型，并通过手势完成模型缩放、旋转和楼层信息导览。",
  "main": "local-dev-server.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "dependencies": {
    "assertion-error": "^2.0.1",
    "cac": "^6.7.14",
    "chai": "^5.3.3",
    "check-error": "^2.1.3",
    "debug": "^4.4.3",
    "deep-eql": "^5.0.2",
    "es-module-lexer": "^1.7.0",
    "esbuild": "^0.27.7",
    "estree-walker": "^3.0.3",
    "expect-type": "^1.3.0",
    "fdir": "^6.5.0",
    "js-tokens": "^9.0.1",
    "loupe": "^3.2.1",
    "magic-string": "^0.30.21",
    "ms": "^2.1.3",
    "nanoid": "^3.3.11",
    "pathe": "^2.0.3",
    "pathval": "^2.0.1",
    "picocolors": "^1.1.1",
    "picomatch": "^4.0.4",
    "postcss": "^8.5.10",
    "rollup": "^4.60.1",
    "siginfo": "^2.0.0",
    "source-map-js": "^1.2.1",
    "stackback": "^0.0.2",
    "std-env": "^3.10.0",
    "strip-literal": "^3.1.0",
    "tinybench": "^2.9.0",
    "tinyexec": "^0.3.2",
    "tinyglobby": "^0.2.16",
    "tinypool": "^1.1.1",
    "tinyrainbow": "^2.0.0",
